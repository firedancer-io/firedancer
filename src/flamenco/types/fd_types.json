        { "name": "parent_blockhash", "type": "hash" },
        { "name": "total_points", "type": "uint128" },
        { "name": "total_rewards", "type": "ulong" },
        { "name": "distributed_rewards", "type": "ulong" },
        { "name": "active", "type": "bool" }
