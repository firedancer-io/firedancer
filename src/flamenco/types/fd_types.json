      "name": "hash",
      "type": "opaque",
      "size": "32",
      "agave": "solana_hash::Hash"
    },
    {
      "name": "pubkey",
      "type": "opaque",
      "size": "32",
      "emitprotos": false,
      "agave": "solana_pubkey::Pubkey"
    },
    {
